modules = ["php-8.2", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["mariadb"]

[userenv]

[userenv.development]
CI_ENVIRONMENT = "development"
APP_STATUS = "installed"
"app.baseURL" = "http://localhost:5000/"
PAYMENT_URL = "http://localhost:5000/"
"database.default.hostname" = "/tmp/mysql.sock"
"database.default.database" = "main"
"database.default.username" = "root"
"database.default.password" = "harry71Nahid920*"
"database.default.DBDriver" = "MySQLi"
"database.default.port" = "3306"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash /home/runner/workspace/start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
